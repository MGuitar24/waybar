{
  "layer": "top",
  "position": "top",
  //"height": 32,
  "spacing": 10,
  "margin-top": 6,
  "margin-left": 10,
  "margin-right": 10,

  // If you have multiple monitors and want the bar on all of them:
  // "output": ["DP-1", "DP-2"],

  "modules-left": [
    "hyprland/workspaces",
    "hyprland/window",
    "custom/updates"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "custom/dualsense",
    "custom/net",
    "custom/net_addr",
    //"network",
    "custom/gpu",
    "cpu",
    "memory",
    "temperature",
    //"pulseaudio",
    "wireplumber",
    "tray"
  ],

  "custom/updates": {
    "format": "󰚰",
    "tooltip": "Updates",
    "on-click": "gtk-launch arch-update"
  },

  "custom/dualsense": {
    "exec": "dualsensectl battery 2>/dev/null | awk '{print $1\"%\", $2}'",
    "interval": 30,
    "format": "🎮 {}",
    "tooltip": false
  },

  "custom/net": {
    "exec": "~/.config/waybar/scripts/net.sh",
    "interval": 1,
    "return-type": "json",
    "format": "{text}",
    "tooltip": "{tooltip}",
    "markup": "pango"
  },

  "custom/net_addr": {
    "exec": "~/.config/waybar/scripts/net_addr.sh",
    "interval": 1,
    "return-type": "json",
    "format": "{text}"
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "●",
      "default": "○",
      "urgent": "◉"
    },
    "persistent-workspaces": {
      "*": 5
    }
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 70,
    "separate-outputs": true,
    "icon": true
  },

  "clock": {
    "interval": 1,
    "format": "{:%d - %I:%M:%S %p}",
    "tooltip-format": "{:%A, %B %d, %Y}"
  },

  "custom/gpu": {
    "exec": "~/.config/waybar/scripts/gpu.sh",
    "interval": 2,
    "return-type": "json",
    "format": "{icon} {text}",
    "format-icons": {
      "gpu": "GPU"
    },
    "tooltip": true
  },

  "cpu": {
    "format": "CPU {usage}%",
    "tooltip": true,
    "states": {
      "low": 20,
      "warning": 40,
      "critical": 60
    }
  },

  "memory": {
    "format": "RAM {percentage}%",
    "tooltip": true,
    "tooltip-format": "RAM: {used:0.1f}GiB / {total:0.1f}GiB",
    "states": {
      "low": 45,
      "warning": 70,
      "critical": 90
    }
  },

  "temperature": {
    "interval": 1,
    "format": "TEMP {temperatureC}°C",
    "critical-threshold": 85,
    "tooltip": true,
    // If temp doesn't show, you may need to set:
    "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input"
  },

  "pulseaudio": {
    "format": "VOL {volume}%",
    "format-muted": "MUTED",
    "scroll-step": 5,
    "on-click": "pavucontrol",
    "tooltip": true,
    "states": {
      "low": 20,
      "warning": 80,
      "critical": 95
    }
  },

  "wireplumber": {
    "format": "VOL {volume}%",
    "format-muted": "MUTED",
    "scroll-step": 5,
    "on-click": "pavucontrol",
    "tooltip": true,
    "states": {
      "low": 20,
      "warning": 80,
      "critical": 95
    }
  },

  "network": {
    "format-ethernet": "WAN {ipaddr}  ↑{bandwidthUpBytes} ↓{bandwidthDownBytes}",
    "format-wifi": "WAN {ipaddr}  ↑{bandwidthUpBytes} ↓{bandwidthDownBytes}",
    "format-disconnected": "NET DOWN",
    "interval": 1,
    "tooltip": false
  },

  "tray": {
    "icon-size": 18,
    "spacing": 8
  }
}

